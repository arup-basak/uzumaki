{
  "name": "uzumaki-monorepo",
  "description": "React Desktop UI Framework without the browser stuff",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "pnpm build:core && pnpm --filter playground dev",
    "build:core": "cargo build --release -p uzumaki",
    "copy:artifacts": "bun scripts/copy-artifacts.ts",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/bun": "latest",
    "prettier": "^3.8.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
